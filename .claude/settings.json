{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/scripts/tokencast-learn.sh\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/scripts/tokencast-midcheck.sh\"'"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/scripts/tokencast-agent-hook.sh\"'"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/estimate-gate.sh\"'"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/validate-agent-type.sh\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/branch-guard.sh\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/scripts/tokencast-track.sh\"'"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/scripts/tokencast-agent-hook.sh\"'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/inline-edit-guard.sh\"'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pre-compact-reminder.sh\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pipeline-gate.sh\"'"
          }
        ]
      }
    ]
  }
}
